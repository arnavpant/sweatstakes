# Supabase — get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service-role key (server-only — never prefix with NEXT_PUBLIC_).
# Required by createAdminClient — used for push fan-out and profile updates that
# write to auth.users.user_metadata. Get from same page as anon key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used as the canonical origin for OAuth redirect URIs
# Set to your production domain on Vercel (e.g., https://sweatstakes.app)
# Falls back to request origin header in development if unset
NEXT_PUBLIC_SITE_URL=

# Deployment notes:
# After deploying to Vercel, add the following to Supabase Auth redirect URIs:
#   https://<your-project>.vercel.app/auth/callback
# Also update Google Cloud Console OAuth redirect URIs to include:
#   https://<supabase-project-ref>.supabase.co/auth/v1/callback
# (This should already be set from Plan 01 setup, but verify it covers production use)

# Supabase Database — Direct connection for Drizzle ORM
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Transaction mode (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Phase 5 — Web Push (generate once via: npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is shipped to the browser to call pushManager.subscribe.
# VAPID_PRIVATE_KEY is server-only; never prefix it with NEXT_PUBLIC_.
# CONTACT_EMAIL is required by the Web Push spec — push services may rate-limit without it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CONTACT_EMAIL=arnav@sweatstakes.app
